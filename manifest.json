{
    "name": "VMware vCenter Connector",
    "description": "Manages Machine SSL and Solution User certificates on VMware vCenter Server Appliances",
    "pluginType": "MACHINE",
    "domainSchema": {
        "connection": {
            "properties": {
                "hostnameOrAddress": {
                    "type": "string",
                    "x-labelLocalizationKey": "address.label",
                    "x-rank": 0
                },
                "port": {
                    "description": "port.description",
                    "maximum": 65535,
                    "minimum": 1,
                    "type": "integer",
                    "x-labelLocalizationKey": "port.label",
                    "x-rank": 1
                },
                "username": {
                    "type": "string",
                    "x-encrypted": true,
                    "x-labelLocalizationKey": "username.label",
                    "x-rank": 2
                },
                "password": {
                    "type": "string",
                    "x-controlOptions": {
                        "password": true,
                        "showPasswordLabel": "password.showPassword",
                        "hidePasswordLabel": "password.hidePassword"
                    },
                    "x-encrypted": true,
                    "x-labelLocalizationKey": "password.label",
                    "x-rank": 3
                }
            },
            "required": [
                "hostnameOrAddress",
                "username",
                "password"
            ],
            "type": "object"
        },
        "certificateBundle": {
            "properties": {
                "certificate": {
                    "contentEncoding": "base64",
                    "type": "string"
                },
                "certificateChain": {
                    "contentEncoding": "base64",
                    "type": "string"
                },
                "privateKey": {
                    "contentEncoding": "base64",
                    "type": "string",
                    "x-encrypted-base64": true
                }
            },
            "required": [
                "certificate",
                "privateKey",
                "certificateChain"
            ],
            "type": "object"
        },
        "keystore": {
            "properties": {
                "certificateType": {
                    "oneOf": [
                        {
                            "const": "machine_ssl",
                            "x-labelLocalizationKey": "certType.machine"
                        },
                        {
                            "const": "vmca_root",
                            "x-labelLocalizationKey": "certType.vmca"
                        }
                    ],
                    "x-labelLocalizationKey": "certType.label",
                    "x-rank": 0
                },
                "autoRestartServices": {
                    "type": "boolean",
                    "default": true,
                    "x-labelLocalizationKey": "services.restartLabel",
                    "x-rank": 1
                }
            },
            "required": [
                "certificateType"
            ],
            "type": "object",
            "x-labelLocalizationKey": "keystore.label",
            "x-primaryKey": [
                "#/certificateType"
            ]
        },
        "discovery": {
            "properties": {
                "includeExpired": {
                    "type": "boolean",
                    "x-labelLocalizationKey": "discovery.expiredLabel",
                    "x-rank": 0
                }
            },
            "type": "object"
        },
        "discoveryControl": {
            "properties": {
                "maxResults": {
                    "type": "integer"
                }
            },
            "required": [
                "maxResults"
            ],
            "type": "object"
        },
        "discoveryPage": {
            "properties": {
                "discoveryType": {
                    "type": "string"
                },
                "paginator": {
                    "type": "string"
                }
            },
            "type": "object"
        }
    },
    "localizationResources": {
        "en": {
            "address": {
                "label": "vCenter Hostname/IP"
            },
            "port": {
                "description": "Defaults to 443 for vCenter vSphere Client APIs",
                "label": "API Port"
            },
            "username": {
                "label": "vCenter Administrator Username"
            },
            "password": {
                "label": "Password",
                "showPassword": "Show Password",
                "hidePassword": "Hide Password"
            },
            "keystore": {
                "label": "vCenter Target Settings"
            },
            "certType": {
                "label": "Certificate Type",
                "machine": "Machine SSL Certificate (Reverse Proxy)",
                "vmca": "VMCA Root Certificate"
            },
            "services": {
                "restartLabel": "Automatically restart vCenter services after installation"
            },
            "discovery": {
                "expiredLabel": "Include expired vCenter certificates in discovery tracking"
            }
        }
    },
    "hooks": {
        "mapping": {
            "configureInstallationEndpoint": "/v1/configureinstallationendpoint",
            "discoverCertificates": "/v1/discovercertificates",
            "installCertificateBundle": "/v1/installcertificatebundle",
            "testConnection": "/v1/testconnection"
        },
        "requestConverters": [
            "arguments-decrypter"
        ]
    }
}