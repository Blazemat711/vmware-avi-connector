{
    "name": "VMware vCenter Connector",
    "description": "Manages SSL/TLS certificates on VMware vCenter appliances",
    "pluginType": "MACHINE",
    "workTypes": [
        "PROVISIONING"
    ],
    "deployment": {
        "executionTarget": "vsat",
        "image": "docker.io/yourregistry/vcenter-connector:latest"
    },
    "domainSchema": {
        "connection": {
            "properties": {
                "hostnameOrAddress": {
                    "type": "string",
                    "x-labelLocalizationKey": "address.label",
                    "x-rank": 0
                },
                "port": {
                    "description": "port.description",
                    "maximum": 65535,
                    "minimum": 1,
                    "type": "integer",
                    "x-labelLocalizationKey": "port.label",
                    "x-rank": 1
                },
                "username": {
                    "type": "string",
                    "x-encrypted": true,
                    "x-labelLocalizationKey": "username.label",
                    "x-rank": 2
                },
                "password": {
                    "type": "string",
                    "x-controlOptions": {
                        "password": true,
                        "showPasswordLabel": "password.showPassword",
                        "hidePasswordLabel": "password.hidePassword"
                    },
                    "x-encrypted": true,
                    "x-labelLocalizationKey": "password.label",
                    "x-rank": 3
                }
            },
            "required": [
                "hostnameOrAddress",
                "username",
                "password"
            ],
            "type": "object"
        },
        "certificateBundle": {
            "properties": {
                "certificate": {
                    "contentEncoding": "base64",
                    "type": "string"
                },
                "certificateChain": {
                    "contentEncoding": "base64",
                    "type": "string"
                },
                "privateKey": {
                    "contentEncoding": "base64",
                    "type": "string",
                    "x-encrypted-base64": true
                }
            },
            "required": [
                "certificate",
                "privateKey",
                "certificateChain"
            ],
            "type": "object"
        },
        "keystore": {
            "properties": {
                "certificateName": {
                    "description": "certificateName.description",
                    "type": "string",
                    "x-labelLocalizationKey": "certificateName.label",
                    "x-rank": 0
                },
                "tenant": {
                    "description": "tenant.description",
                    "type": "string",
                    "x-labelLocalizationKey": "tenant.label",
                    "x-rank": 1
                }
            },
            "required": [
                "certificateName"
            ],
            "type": "object",
            "x-labelLocalizationKey": "keystore.label",
            "x-primaryKey": [
                "#/certificateName"
            ]
        },
        "binding": {
            "properties": {
                "virtualServiceName": {
                    "type": "string",
                    "x-labelLocalizationKey": "virtualServiceName.label",
                    "x-rank": 0
                }
            },
            "required": [
                "virtualServiceName"
            ],
            "type": "object",
            "x-labelLocalizationKey": "binding.label",
            "x-primaryKey": [
                "#/virtualServiceName"
            ]
        }
    },
    "localizationResources": {
        "en": {
            "address": {
                "label": "Server Hostname"
            },
            "port": {
                "description": "No value is interpreted as 443",
                "label": "Port"
            },
            "username": {
                "label": "Username"
            },
            "password": {
                "label": "Password",
                "showPassword": "Show Password",
                "hidePassword": "Hide Password"
            },
            "keystore": {
                "label": "Certificate Information"
            },
            "binding": {
                "label": "Server Store Details"
            },
            "tenant": {
                "description": "The tenancy or folder for the certificate in vCenter",
                "label": "Tenant"
            },
            "virtualServiceName": {
                "description": "The target vCenter entity or service to configure",
                "label": "Target Service"
            },
            "certificateName": {
                "description": "How the certificate should appear on the server",
                "label": "Certificate Name"
            },
            "chainName": {
                "label": "Chain Bundle Name"
            },
            "partition": {
                "description": "No value is interpreted as the \"Common\" partition",
                "label": "Partition"
            },
            "sslProfile": {
                "label": "SSL Profile"
            },
            "parentProfile": {
                "description": "No value is interpreted as \"clientssl\" or \"serverssl\" depending on the Profile Type selected",
                "label": "Parent Profile"
            },
            "sslProfileType": {
                "label": "Profile Type",
                "client": "Client SSL Profile",
                "server": "Server SSL Profile"
            },
            "serverName": {
                "description": "An alternative DNS name used for Server Name Indication",
                "label": "SNI"
            },
            "discovery": {
                "partitionLabel": "Partition(s)",
                "partitionDescription": "A comma separated list of partition names.",
                "expiredCertificatesLabel": "Exclude expired certificates",
                "inactiveProfilesLabel": "Exclude certificates that are not in use by either a virtual server or a monitor."
            },
            "discoveryType": {
                "label": "Resource Types to Discover",
                "all": "Both Monitors and Virtual Servers",
                "monitor": "Monitors",
                "virtualServer": "Virtual Servers"
            }
        }
    },
    "hooks": {
        "mapping": {
            "configureInstallationEndpoint": "/v1/configureinstallationendpoint",
            "discoverCertificates": "/v1/discovercertificates",
            "installCertificateBundle": "/v1/installcertificatebundle",
            "testConnection": "/v1/testconnection"
        },
        "requestConverters": [
            "arguments-decrypter"
        ]
    }
}